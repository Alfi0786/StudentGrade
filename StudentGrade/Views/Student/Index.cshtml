@model List<StudentGrade.Dto.StudentDisplayDto>
@{
    ViewBag.Title = "Student List";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- test -->
<style>
    body {
        min-height: 100vh;
        background: linear-gradient(135deg, #0d1b2a 0%, #1b263b 50%, #000 100%);
        color: #f8f9fa;
    }

    .container-custom {
        background: rgba(13, 27, 42, 0.95);
        border-radius: 1.5rem;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
        padding: 2rem 2.5rem;
        margin-top: 3rem;
    }

    .form-control, .form-select {
        border-radius: 1rem;
    }

    .table {
        background: rgba(24, 39, 64, 0.95);
        border-radius: 1rem;
        overflow: hidden;
    }

        .table th, .table td {
            vertical-align: middle;
        }

        .table thead {
            background: linear-gradient(90deg, #1b263b 0%, #0d1b2a 100%);
            color: #fff;
        }

    .table-striped > tbody > tr:nth-of-type(odd) {
        background-color: rgba(34, 49, 63, 0.7);
    }

    .btn-custom {
        background: linear-gradient(90deg, #274690 0%, #142850 100%);
        color: #fff;
        border: none;
        border-radius: 1rem;
        transition: background 0.3s;
    }

        .btn-custom:hover {
            background: linear-gradient(90deg, #142850 0%, #274690 100%);
            color: #fff;
        }

    @@media (max-width: 576px) {
        .container-custom {
            padding: 1rem 0.5rem;
        }

        .table-responsive {
            font-size: 0.95rem;
        }
    }
</style>

<div class="container container-custom shadow-lg">
    <h2 class="mb-4 text-center fw-bold" style="letter-spacing: 2px;">Student List</h2>

    <div class="mb-3 text-end">
        <button type="button" class="btn btn-custom" id="addStudentBtn">
            Add Student
        </button>
    </div>

    <!-- Unified Add/Edit Student Modal -->
    <div class="modal fade" id="studentModal" tabindex="-1" aria-labelledby="studentModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content" style="background: #1b263b; color: #fff; border-radius: 1rem;">
                <div class="modal-header" style="border-bottom: 1px solid #274690;">
                    <h5 class="modal-title" id="studentModalLabel">Add Student</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="studentForm" method="post" asp-action="Upsert">
                    <div class="modal-body">
                        <input type="hidden" id="StudentId" name="StudentId" />
                        <div class="mb-3">
                            <label for="StudentName" class="form-label">Student Name</label>
                            <input type="text" class="form-control" id="StudentName" placeholder="Enter student name" name="StudentName" required>
                        </div>
                        <div class="mb-3">
                            <label for="SubjectName" class="form-label">Subject</label>
                            <input type="text" class="form-control" id="SubjectName" placeholder="Enter subject name" name="SubjectName" required>
                        </div>
                        <div class="mb-3">
                            <label for="Grade" class="form-label">Grade</label>
                            <input type="number" class="form-control" id="Grade" placeholder="Enter grade" name="Grade" min="0" max="100" required>
                        </div>
                        <input type="hidden" id="Remarks" name="Remarks" />
                    </div>
                    <div class="modal-footer" style="border-top: 1px solid #274690;">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-custom" id="modalSubmitBtn">Add</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <form method="get" asp-controller="Student" asp-action="Index" class="row g-3 mb-4 justify-content-center">
        <div class="col-md-4 col-12">
            <input type="text" name="searchName" value="@ViewBag.SearchName" class="form-control" placeholder="Search by student name" />
        </div>
        <div class="col-md-3 col-8">
            <select name="remarksFilter" class="form-select">
                <option value="ALL">All</option>
                <option value="Passed">Passed</option>
                <option value="Failed">Failed</option>
            </select>
            <script>
                document.querySelector('[name="remarksFilter"]').value = '@ViewBag.RemarksFilter';
            </script>
        </div>
        <div class="col-md-2 col-4">
            <button type="submit" class="btn btn-custom w-100">Search/Filter</button>
        </div>
    </form>

    <div class="table-responsive rounded">
        <table class="table table-dark table-striped table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Student Name</th>
                    <th>Subject Name</th>
                    <th>Grade</th>
                    <th>Remarks</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var student in Model)
                    {
                        <tr>
                            <td>@student.StudentName</td>
                            <td>@student.SubjectName</td>
                            <td>@student.Grade</td>
                            <td>
                                <span class="badge rounded-pill @(student.Remarks == "Passed" ? "bg-success" : "bg-danger")">
                                    @student.Remarks
                                </span>
                            </td>
                            <td>
                                <!-- EDIT BUTTON -->
                                <button type="button"
                                        class="btn btn-sm btn-warning me-2 editStudentBtn"
                                        data-student-id="@student.StudentId"
                                        data-student-name="@student.StudentName"
                                        data-subject-name="@student.SubjectName"
                                        data-grade="@student.Grade"
                                        data-remarks="@student.Remarks">
                                    Edit
                                </button>
                                <!-- DELETE BUTTON -->
                                <a asp-action="Delete"
                                   asp-route-id="@student.StudentId"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('Are you sure you want to delete this student?');">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-secondary">No students found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Add Student button
        document.getElementById('addStudentBtn').addEventListener('click', function () {
            document.getElementById('studentModalLabel').textContent = 'Add Student';
            document.getElementById('modalSubmitBtn').textContent = 'Add';
            document.getElementById('studentForm').reset();
            document.getElementById('StudentId').value = '';
            document.getElementById('Remarks').value = '';
            var modal = new bootstrap.Modal(document.getElementById('studentModal'));
            modal.show();
        });

        // Edit Student buttons
        document.querySelectorAll('.editStudentBtn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.getElementById('studentModalLabel').textContent = 'Edit Student';
                document.getElementById('modalSubmitBtn').textContent = 'Update';
                document.getElementById('StudentId').value = this.getAttribute('data-student-id');
                document.getElementById('StudentName').value = this.getAttribute('data-student-name');
                document.getElementById('SubjectName').value = this.getAttribute('data-subject-name');
                document.getElementById('Grade').value = this.getAttribute('data-grade');
                document.getElementById('Remarks').value = this.getAttribute('data-remarks');
                var modal = new bootstrap.Modal(document.getElementById('studentModal'));
                modal.show();
            });
        });
    </script>
}